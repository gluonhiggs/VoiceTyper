# Copy this file to `config.toml` (which is gitignored) and fill in your key.
# The v1.1 settings UI will eventually write this file for you.
#
#   Copy-Item config.toml.example config.toml   # then edit config.toml

groq_api_key = "gsk_your_groq_api_key_here"
model = "whisper-large-v3-turbo"

# Dictation mode:
#   "handsfree" = press Ctrl+Win once, talk; it types each sentence as you pause.
#   "toggle"    = press to start, press to stop; types one clean transcription
#                 (full context = better capitalization/punctuation).
mode = "toggle"
